# 실행 호출 스펙 템플릿 (key=value)
# required: call_id, profile, source_files

call_id=SIM-R01-0001
profile=simulation
mode=simulation
round=R01

# bundle 루트 기준 상대경로, comma-separated
source_files=world_bible/WB-0003_onepage_summary.md,characters/CH-0001_char-mc-001.md,docs/community_map.md

# simulation/writing 기본값: no
# orchestrator는 강제로 yes 처리됨
allow_confidential=no
allow_character_confidential=no

# world_bible의 visibility: CONFIDENTIAL 섹션 중 허용할 id 목록
# 예: WB-0011,WB-0015
allow_confidential_ids=
